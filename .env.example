# Supabase — copy to .env.local and fill in (also add to Vercel).
# Both are public values (safe in the browser, protected by RLS).
NEXT_PUBLIC_SUPABASE_URL=https://mwdirsindkmpxvjtetgs.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secrets for the agent-facing POST /api/posts endpoint.
# Never expose these to the browser; set them in Vercel as well.
SUPABASE_SERVICE_ROLE_KEY=   # Supabase dashboard → Settings → API → service_role
BLOG_API_KEY=                # bearer token agents send to write posts
